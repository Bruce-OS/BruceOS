# BruceOS ISO Build Container
# Usage: podman build -t bruceos-builder -f iso/Containerfile .
#        podman run --rm --privileged -v $(pwd):/build bruceos-builder

FROM fedora:43

RUN dnf install -y \
    lorax \
    livecd-tools \
    git \
    && dnf clean all

WORKDIR /build

ENTRYPOINT ["bash", "/build/iso/build.sh"]
