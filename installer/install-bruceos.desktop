[Desktop Entry]
Type=Application
Name=Install BruceOS
GenericName=System Installer
Comment=Install BruceOS to your hard drive
Exec=pkexec env DISPLAY=$DISPLAY XAUTHORITY=$XAUTHORITY WAYLAND_DISPLAY=$WAYLAND_DISPLAY XDG_RUNTIME_DIR=$XDG_RUNTIME_DIR calamares
Icon=bruceos-logo
Terminal=false
Categories=System;
Keywords=install;calamares;system;
StartupNotify=true
StartupWMClass=calamares
X-GNOME-Autostart-enabled=false
